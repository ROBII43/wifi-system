# Flask settings
SECRET_KEY=replace-with-a-secure-random-string
DEBUG=False
TESTING=False
SESSION_COOKIE_SECURE=True

# Database settings
DB_HOST=localhost
DB_USER=wifi_user
DB_PASSWORD=replace-with-database-password
DB_NAME=wifi_system

# Lipana payment gateway
LIPANA_PUBLISHABLE_KEY=your_lipana_publishable_key
LIPANA_SECRET_KEY=your_lipana_secret_key
LIPANA_CALLBACK_URL=https://your-domain.com/webhook/callback

# MikroTik router access
MIKROTIK_HOST=192.168.88.1
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=replace-with-router-password

# Admin user credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
